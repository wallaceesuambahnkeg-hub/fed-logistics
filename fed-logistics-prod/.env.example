PORT=3000
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-string

# Your deployed URL (important for email links to work!)
# In development: http://localhost:3000
# On Render: https://fed-logistics.onrender.com
APP_URL=https://fed-logistics.onrender.com

DB_PATH=./database/logistics.db

# Gmail credentials for sending emails
# Get App Password: Google Account > Security > 2-Step Verification > App passwords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-character-app-password
EMAIL_TO=admin@fedlogistics.com
ADMIN_EMAIL=your-admin-email@gmail.com
VITE_ADMIN_EMAIL=your-admin-email@gmail.com
